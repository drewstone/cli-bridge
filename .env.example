# cli-bridge configuration — copy to .env and edit.

# --- Network ---
# Default binds to 127.0.0.1 (localhost only). Override ONLY if you know
# what you're doing and have a bearer check in place (BRIDGE_BEARER).
BRIDGE_HOST=127.0.0.1
# 3344 chosen to dodge common dev/service collisions (8787, 4098, etc.)
BRIDGE_PORT=3344

# When BRIDGE_HOST is anything other than 127.0.0.1 / ::1 / localhost, the
# server REFUSES to start without BRIDGE_BEARER set.
# Generate with: openssl rand -hex 32
# BRIDGE_BEARER=

# --- Storage ---
BRIDGE_DATA_DIR=./data

# --- Backends ---
# Comma-separated. Model ids are `<harness>/<model>` — the harness name
# here is what matches the id prefix. Unknown or missing-CLI backends
# are reported by /health with state=unavailable.
#
# Harnesses:
#   claude      — Claude Code CLI, real Anthropic
#   claudish    — Claude Code CLI + claudish proxy (ANTHROPIC_BASE_URL override)
#   kimi        — Kimi Code CLI (Moonshot subscription)
#   sandbox     — Tangle sandbox-api + AgentProfile catalog (profiles/*.json)
#   codex       — OpenAI Codex CLI
#   opencode    — opencode CLI (multi-provider; vehicle for Kimi Code via plugin)
#   factory     — Factory Droid (stub)
#   amp         — Sourcegraph Amp (stub)
#   forge       — OSS Forge (stub)
#   passthrough — direct vendor API call (openai/, anthropic/, moonshot/, zai/)
BRIDGE_BACKENDS=claude,kimi,sandbox,passthrough

# --- CLI timeouts (applies to all backends unless overridden) ---
# CLI_TIMEOUT_MS=300000

# --- claude / claudish ---
# CLAUDE_BIN=/usr/local/bin/claude
# CLAUDE_TIMEOUT_MS=300000

# URL of a running claudish proxy. Only required if `claudish` is in
# BRIDGE_BACKENDS. https://github.com/MadAppGang/claudish
# CLAUDISH_URL=http://127.0.0.1:3456

# --- codex ---
# CODEX_BIN=codex
# CODEX_TIMEOUT_MS=300000

# --- opencode ---
# OPENCODE_BIN=opencode
# OPENCODE_TIMEOUT_MS=300000

# --- kimi ---
# KIMI_BIN=kimi
# KIMI_TIMEOUT_MS=300000

# --- factory / amp / forge (stubs) ---
# FACTORY_BIN=droid
# AMP_BIN=amp
# FORGE_BIN=forge

# --- Sandbox ---
# SANDBOX_API_URL=https://sandbox.tangle.tools
# SANDBOX_API_KEY=
# SANDBOX_PROFILES_DIR=./profiles
# SANDBOX_TIMEOUT_MS=300000

# --- Passthrough provider keys ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# MOONSHOT_API_KEY=
# ZAI_API_KEY=
