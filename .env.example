# cli-bridge configuration — copy to .env and edit.

# --- Network ---
# Default binds to 127.0.0.1 (localhost only). Override ONLY if you know
# what you're doing and have a bearer check in place (see BRIDGE_BEARER).
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8787

# When BRIDGE_HOST is anything other than 127.0.0.1 / ::1 / localhost, the
# server REFUSES to start without BRIDGE_BEARER set — a deliberate guard
# against accidental open proxies.
#
# Generate with: openssl rand -hex 32
# BRIDGE_BEARER=

# --- Storage ---
BRIDGE_DATA_DIR=./data

# --- Backends ---
# Comma-separated list of backends to enable. Unknown or missing-CLI
# backends are reported by /health with state=unavailable.
#
# Known backends: claude, codex, opencode, passthrough
BRIDGE_BACKENDS=claude,passthrough

# Passthrough API keys — used when the request's model isn't claimed by a
# CLI backend. Optional; unset providers silently skip.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# MOONSHOT_API_KEY=
# ZAI_API_KEY=                     # Z.AI (GLM-* models)

# --- Claude Code with a different brain ---
# When set, the Claude Code subprocess is spawned with ANTHROPIC_BASE_URL
# pointing here. Classic pairing: run `claudish` on localhost and point
# this at it, so Claude Code's workflow drives a Z.AI / OpenRouter /
# Gemini model. See README.
# CLAUDE_ANTHROPIC_BASE_URL=http://127.0.0.1:3456

# --- Claude Code backend ---
# Override path if `claude` isn't on $PATH.
# CLAUDE_BIN=/usr/local/bin/claude
# Default 5 minute cap per turn.
CLAUDE_TIMEOUT_MS=300000
