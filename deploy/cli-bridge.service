[Unit]
Description=cli-bridge — local coding-CLI HTTP proxy
After=network.target
Requires=network.target

[Service]
Type=simple
User=%i
WorkingDirectory=/srv/cli-bridge
EnvironmentFile=/srv/cli-bridge/.env
ExecStart=/usr/bin/env pnpm start
Restart=always
RestartSec=5
# Capture stdout/stderr to journal
StandardOutput=journal
StandardError=journal

# Security hardening — cli-bridge reads ~/.claude and spawns `claude`,
# so it DOES need HOME + a writable data dir, but nothing else.
PrivateTmp=true
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/srv/cli-bridge/data
ProtectHome=false

[Install]
WantedBy=multi-user.target
