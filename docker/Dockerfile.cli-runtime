# Unified CLI runtime image — used by every backend's Docker executor pool.
#
# Each container in the pool runs `tail -f /dev/null` as its idle entrypoint;
# cli-bridge dispatches real CLI invocations via `docker exec <slot> claude
# -p …` (or kimi / codex / opencode equivalents). One image serves any
# backend, so a single pool can be reused or per-backend pools all share
# the same image — your call via the per-backend image env knobs.
#
# Why one image and not four:
#   - Same Node base, same toolchain prereqs, same dumb-init story
#   - Independent CLI versioning happens at the npm/installer level inside
#     the image, not at the Dockerfile level
#   - Disk footprint of installing all four CLIs on top of one Node layer
#     is significantly smaller than four separate images each with its
#     own Node base
#
# Build:
#   docker build -f docker/Dockerfile.cli-runtime -t cli-bridge-cli-runtime:latest .
#
# OAuth state lives at:
#   /root/.claude            — Claude Code
#   /root/.kimi              — Kimi CLI auth
#   /root/.config/kimi       — Kimi CLI config
#   /root/.codex             — OpenAI Codex
#   /root/.config/opencode   — opencode
#   /root/.opencode          — opencode binary install dir
#
# The bridge's container-pool config bind-mounts only the dirs the
# active backend needs.

FROM node:22-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
       git ca-certificates dumb-init curl python3 \
  && rm -rf /var/lib/apt/lists/*

# --- CLI installs (each pinned/latest at image-build time) ---

# Claude Code — npm-installed.
RUN npm install -g @anthropic-ai/claude-code@latest

# OpenAI Codex — npm-installed.
RUN npm install -g @openai/codex@latest

# opencode — official installer drops the binary at /root/.opencode/bin.
# Copy to /usr/local/bin so the binary survives a volume mount onto the
# host's ~/.opencode if the bridge mounts it for OAuth state.
RUN curl -fsSL https://opencode.ai/install | bash \
  && cp /root/.opencode/bin/opencode /usr/local/bin/opencode \
  && chmod +x /usr/local/bin/opencode

# Kimi CLI — uv-managed Python tool. Symlink so PATH picks it up at runtime.
RUN curl -LsSf https://astral.sh/uv/install.sh | sh \
  && /root/.local/bin/uv tool install --python 3.13 kimi-cli \
  && ln -sf /root/.local/bin/kimi /usr/local/bin/kimi \
  && ln -sf /root/.local/bin/uv   /usr/local/bin/uv

# OAuth + config volumes (mount from host or per-slot named volumes).
VOLUME /root/.claude
VOLUME /root/.codex
VOLUME /root/.kimi
VOLUME /root/.config/kimi
VOLUME /root/.config/opencode
VOLUME /root/.opencode

# Workspace dir for cwd-scoped tool calls.
WORKDIR /workspace

# Idle entrypoint — bridge dispatches actual CLI calls via `docker exec`.
ENTRYPOINT ["dumb-init", "--"]
CMD ["tail", "-f", "/dev/null"]
